---
import FlipCards, { type FlipCardItem } from './FlipCards.astro';

interface Props {
	seccion: 'naturaleza' | 'publico' | 'instrumentos';
}

const { seccion } = Astro.props;
---

{
	seccion === 'naturaleza' && (
		<div class="mt-6 border-t border-teal-100 pt-5">
			<FlipCards
				theme="teal"
				title="Contratos TI"
				helperText="Toca o pasa el cursor para girar cada tarjeta."
				items={[
					{
						id: 't2-cti',
						badge: 'Concepto',
						frontTitle: 'Contratos informáticos',
						frontSubtitle: 'Acuerdos entre partes',
						backBody:
							'Acuerdos legales entre dos o más partes para regular operaciones comerciales sobre bienes, suministros y/o servicios informáticos.',
					},
					{
						id: 't2-bienes',
						badge: 'Objeto',
						frontTitle: 'Bienes informáticos',
						frontSubtitle: 'Hardware + software',
						backBody:
							'Elementos materiales del sistema (hardware) y programas (software) que permiten su funcionamiento.',
					},
					{
						id: 't2-sumin',
						badge: 'Objeto',
						frontTitle: 'Suministros informáticos',
						frontSubtitle: 'Insumos para operar',
						backBody:
							'Productos y herramientas para registrar información, abastecer equipos, programar y mantener componentes materiales.',
					},
					{
						id: 't2-serv',
						badge: 'Objeto',
						frontTitle: 'Servicios informáticos',
						frontSubtitle: 'Actividades de apoyo',
						backBody:
							'Conjunto de actividades que apoyan y optimizan el funcionamiento de los sistemas y sus componentes.',
					},
				] satisfies FlipCardItem[]}
			/>

			<div class="mt-5">
				<FlipCards
					theme="teal"
					title="Tipos de servicios TI"
					columns={3}
					items={[
						{
							id: 't2-srv-remote',
							badge: 'Servicio',
							frontTitle: 'Apoyo a distancia',
							frontSubtitle: 'Soporte remoto',
							backBody: 'Asistencia técnica a distancia para resolver incidencias y orientar al usuario.',
						},
						{
							id: 't2-srv-dev',
							badge: 'Servicio',
							frontTitle: 'Desarrollo de software',
							frontSubtitle: 'A medida',
							backBody: 'Creación o adaptación de aplicaciones para necesidades específicas.',
						},
						{
							id: 't2-srv-train',
							badge: 'Servicio',
							frontTitle: 'Formación tecnológica',
							frontSubtitle: 'Capacitación',
							backBody: 'Entrenamiento para usar herramientas y software actualizados con eficacia.',
						},
						{
							id: 't2-srv-hw',
							badge: 'Servicio',
							frontTitle: 'Hardware',
							frontSubtitle: 'Instalación y mantenimiento',
							backBody: 'Instalación, mantenimiento y reparación de equipos y componentes.',
						},
						{
							id: 't2-srv-cloud',
							badge: 'Servicio',
							frontTitle: 'Nube',
							frontSubtitle: 'Almacenamiento y acceso',
							backBody: 'Servicios conectados a Internet para almacenar y acceder a información y programas.',
						},
						{
							id: 't2-srv-mail',
							badge: 'Servicio',
							frontTitle: 'Correo electrónico',
							frontSubtitle: 'Comunicación',
							backBody: 'Uso empresarial del correo para comunicaciones y operación organizacional.',
						},
						{
							id: 't2-srv-netsec',
							badge: 'Servicio',
							frontTitle: 'Seguridad de red',
							frontSubtitle: 'Protección',
							backBody: 'Cortafuegos, antivirus, VPN y revisiones periódicas para prevenir accesos no autorizados.',
						},
						{
							id: 't2-srv-monitor',
							badge: 'Servicio',
							frontTitle: 'Seguimiento',
							frontSubtitle: 'Monitoreo',
							backBody: 'Supervisión de red, tráfico, equipos y dispositivos conectados para detectar fallas o riesgos.',
						},
						{
							id: 't2-srv-saas',
							badge: 'Servicio',
							frontTitle: 'SaaS',
							frontSubtitle: 'Suscripción',
							backBody: 'Software como servicio: programas de uso recurrente con pago por suscripción.',
						},
					] satisfies FlipCardItem[]}
				/>
			</div>
		</div>
	)
}

{
	seccion === 'publico' && (
		<div class="mt-6 border-t border-teal-100 pt-5">
			<FlipCards
				theme="teal"
				title="Pública vs. privada"
				items={[
					{
						id: 't2-pub',
						badge: 'Régimen',
						frontTitle: 'Contratación pública',
						frontSubtitle: 'Fondos públicos',
						backBody:
							'Proceso mediante el cual entidades gubernamentales adquieren bienes, servicios u obras con fondos públicos para cumplir sus funciones y objetivos.',
					},
					{
						id: 't2-priv',
						badge: 'Régimen',
						frontTitle: 'Contratación privada',
						frontSubtitle: 'Negociación directa',
						backBody:
							'Acuerdos entre particulares o entidades privadas sin participación directa del Estado; se rige por derecho privado (civil o mercantil).',
					},
				] satisfies FlipCardItem[]}
			/>

			<div class="mt-5">
				<FlipCards
					theme="teal"
					title="Proceso público (pasos)"
					columns={3}
					items={[
						{
							id: 't2-step-1',
							badge: 'Paso',
							frontTitle: 'Solicitud de cotización',
							frontSubtitle: 'Publicación del requerimiento',
							backBody: 'Se publica el requerimiento en la TVEC para iniciar la búsqueda de proveedores.',
						},
						{
							id: 't2-step-2',
							badge: 'Paso',
							frontTitle: 'Evaluación de ofertas',
							frontSubtitle: 'Técnica + económica',
							backBody: 'Se analizan las propuestas y se verifica el cumplimiento de requisitos.',
						},
						{
							id: 't2-step-3',
							badge: 'Paso',
							frontTitle: 'Orden de compra',
							frontSubtitle: 'Formalización',
							backBody: 'Se formaliza la adquisición (en compras por AMP, es el documento clave).',
						},
						{
							id: 't2-step-4',
							badge: 'Paso',
							frontTitle: 'Entrega y soporte',
							frontSubtitle: 'Instalación + garantía',
							backBody: 'Incluye entrega, instalación, capacitación, soporte y garantías según condiciones.',
						},
						{
							id: 't2-inst-amp',
							badge: 'Instrumento',
							frontTitle: 'AMP',
							frontSubtitle: 'Condiciones preestablecidas',
							backBody: 'Permite comprar computadores, periféricos y software con reglas y precios acordados previamente.',
						},
						{
							id: 't2-inst-sec',
							badge: 'Plataforma',
							frontTitle: 'SECOP II',
							frontSubtitle: 'Gestión y trazabilidad',
							backBody: 'Soporta gestión y registro del ciclo contractual con trazabilidad de actuaciones.',
						},
					] satisfies FlipCardItem[]}
				/>
			</div>

			<div class="mt-5">
				<FlipCards
					theme="teal"
					title="Buenas prácticas (privada)"
					items={[
						{
							id: 't2-bp-1',
							badge: 'Práctica',
							frontTitle: 'Estudio de mercado',
							frontSubtitle: 'Comparar opciones',
							backBody: 'Recolectar cotizaciones y alternativas para decidir con información suficiente.',
						},
						{
							id: 't2-bp-2',
							badge: 'Práctica',
							frontTitle: 'Especificaciones claras',
							frontSubtitle: 'Técnicas + alcance',
							backBody: 'Definir requisitos técnicos, alcance, entregables, tiempos y criterios de aceptación.',
						},
						{
							id: 't2-bp-3',
							badge: 'Práctica',
							frontTitle: 'Garantías y soporte',
							frontSubtitle: 'Posventa',
							backBody: 'Acordar garantías, soporte, actualizaciones y condiciones de mantenimiento.',
						},
						{
							id: 't2-bp-4',
							badge: 'Práctica',
							frontTitle: 'Formalización',
							frontSubtitle: 'Contrato u orden',
							backBody: 'Documentar acuerdos para disminuir riesgos: precio, alcance, penalidades, responsabilidades.',
						},
					] satisfies FlipCardItem[]}
				/>
			</div>
		</div>
	)
}

{
	seccion === 'instrumentos' && (
		<div class="mt-6 border-t border-teal-100 pt-5">
			<FlipCards
				theme="violet"
				title="Instrumentos"
				items={[
					{
						id: 't2-i-tvec',
						badge: 'Plataforma',
						frontTitle: 'TVEC',
						frontSubtitle: 'Catálogo y compra ágil',
						backBody:
							'Concentra compras sobre catálogos negociados; facilita cotización, selección y orden de compra en adquisiciones recurrentes.',
					},
					{
						id: 't2-i-amp',
						badge: 'Instrumento',
						frontTitle: 'AMP',
						frontSubtitle: 'Agrega demanda',
						backBody:
							'Establece condiciones de precio y calidad para compras simplificadas por parte de entidades.',
					},
					{
						id: 't2-i-sec',
						badge: 'Plataforma',
						frontTitle: 'SECOP II',
						frontSubtitle: 'Ciclo contractual',
						backBody:
							'Gestión y registro electrónico del proceso para asegurar trazabilidad y publicidad.',
					},
				] satisfies FlipCardItem[]}
			/>
			<p class="mt-3 text-xs text-neutral-600">
				Enlace:{' '}
				<a
					href="https://operaciones.colombiacompra.gov.co/content/tienda-virtual"
					class="font-medium text-violet-700 underline hover:text-violet-900"
					target="_blank"
					rel="noopener noreferrer"
				>
					Tienda Virtual del Estado
				</a>
				.
			</p>
		</div>
	)
}
