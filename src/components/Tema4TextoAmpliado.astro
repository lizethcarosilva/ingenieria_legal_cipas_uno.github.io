---
import FlipCards, { type FlipCardItem } from './FlipCards.astro';

interface Props {
	seccion: 'licencia' | 'partes' | 'autor';
}

const { seccion } = Astro.props;
---

{
	seccion === 'licencia' && (
		<div class="mt-6 border-t border-indigo-100 pt-5">
			<FlipCards
				theme="indigo"
				title="Licenciamiento (idea central)"
				items={[
					{
						id: 't4-core',
						badge: 'Concepto',
						frontTitle: 'Licenciamiento de software',
						frontSubtitle: 'Uso sin transferir titularidad',
						backBody:
							'El titular (licenciante) concede autorización de uso al licenciatario, usualmente a cambio de precio o canon, sin transferir la propiedad intelectual.',
					},
					{
						id: 't4-types',
						badge: 'Tipos',
						frontTitle: 'Exclusiva / no exclusiva',
						frontSubtitle: '¿Licencia única?',
						backBody:
							'Exclusiva: el licenciante no otorga licencias a otros. No exclusiva: puede licenciar a varios usuarios.',
					},
					{
						id: 't4-transfer',
						badge: 'Tipos',
						frontTitle: 'Transferible / no',
						frontSubtitle: '¿Puede sublicenciar?',
						backBody:
							'Transferible: el licenciatario puede ceder o sublicenciar (según contrato). No transferible: se restringe a quien recibe la licencia.',
					},
					{
						id: 't4-common',
						badge: 'Frecuente',
						frontTitle: 'Más común',
						frontSubtitle: 'No exclusiva + no transferible',
						backBody:
							'Lo habitual: licenciante puede licenciar a otros; licenciatario no puede sublicenciar.',
					},
				] satisfies FlipCardItem[]}
			/>

			<div class="mt-5">
				<FlipCards
					theme="violet"
					title="Licencia vs. cesión vs. desarrollo"
					columns={3}
					items={[
						{
							id: 't4-cesion',
							badge: 'Contrato',
							frontTitle: 'Cesión de software',
							frontSubtitle: 'Transfiere titularidad',
							backBody: 'El cedente transmite la titularidad/propiedad del software al cesionario a cambio de precio.',
						},
						{
							id: 't4-lic',
							badge: 'Contrato',
							frontTitle: 'Licencia de software',
							frontSubtitle: 'Transfiere uso',
							backBody: 'Se concede un derecho de uso; el licenciante conserva la titularidad.',
						},
						{
							id: 't4-dev',
							badge: 'Contrato',
							frontTitle: 'Desarrollo de software',
							frontSubtitle: 'Crea o adapta',
							backBody: 'El desarrollador elabora software según instrucciones o necesidades específicas del cliente.',
						},
					] satisfies FlipCardItem[]}
				/>
			</div>

			<div class="mt-5">
				<FlipCards
					theme="indigo"
					title="Tipos de licencias"
					columns={3}
					items={[
						{
							id: 't4-lic-prop',
							badge: 'Licencia',
							frontTitle: 'Propietaria',
							frontSubtitle: 'Uso limitado',
							backBody: 'Uso según contrato; no permite modificar ni distribuir libremente.',
						},
						{
							id: 't4-lic-free',
							badge: 'Licencia',
							frontTitle: 'Freeware',
							frontSubtitle: 'Gratis',
							backBody: 'Uso gratuito, generalmente sin acceso al código fuente.',
						},
						{
							id: 't4-lic-share',
							badge: 'Licencia',
							frontTitle: 'Shareware',
							frontSubtitle: 'Prueba',
							backBody: 'Uso gratuito por tiempo limitado; luego requiere pago.',
						},
						{
							id: 't4-lic-oss',
							badge: 'Licencia',
							frontTitle: 'Open source',
							frontSubtitle: 'Código disponible',
							backBody: 'Permite ver, modificar y distribuir el código bajo condiciones de la licencia.',
						},
						{
							id: 't4-lic-custom',
							badge: 'Licencia',
							frontTitle: 'Personalizada',
							frontSubtitle: 'A medida',
							backBody: 'Adaptada a necesidades específicas del cliente (usuarios, sedes, soporte, etc.).',
						},
					] satisfies FlipCardItem[]}
				/>
			</div>
		</div>
	)
}

{
	seccion === 'partes' && (
		<div class="mt-6 border-t border-indigo-100 pt-5">
			<FlipCards
				theme="indigo"
				title="Partes y figura clave"
				items={[
					{
						id: 't4-contratante',
						badge: 'Parte',
						frontTitle: 'Contratante',
						frontSubtitle: 'Necesidad y pago',
						backBody: 'Encarga la prestación o entrega y suscribe el contrato para satisfacer una necesidad.',
					},
					{
						id: 't4-contratista',
						badge: 'Parte',
						frontTitle: 'Contratista',
						frontSubtitle: 'Ejecución',
						backBody: 'Se obliga a ejecutar la prestación (obra/servicio/suministro) a cambio de remuneración.',
					},
					{
						id: 't4-cesion',
						badge: 'Figura',
						frontTitle: 'Cesión del contrato',
						frontSubtitle: 'Traslado de posición',
						backBody: 'Transfiere derechos y obligaciones a un tercero; suele requerir consentimiento de la contraparte.',
					},
				] satisfies FlipCardItem[]}
			/>
		</div>
	)
}

{
	seccion === 'autor' && (
		<div class="mt-6 border-t border-indigo-100 pt-5">
			<FlipCards
				theme="indigo"
				title="Autor y control"
				columns={3}
				items={[
					{
						id: 't4-da',
						badge: 'Derecho',
						frontTitle: 'Derecho de autor',
						frontSubtitle: 'Protege la obra',
						backBody: 'Reconoce derechos morales (paternidad, integridad) y patrimoniales (explotación) sobre el software.',
					},
					{
						id: 't4-int',
						badge: 'Rol',
						frontTitle: 'Interventor',
						frontSubtitle: 'Supervisión integral',
						backBody: 'Verifica cumplimiento técnico, administrativo, financiero, contable y jurídico del contrato (según encargo).',
					},
					{
						id: 't4-sup',
						badge: 'Rol',
						frontTitle: 'Supervisor',
						frontSubtitle: 'Seguimiento',
						backBody: 'Servidor designado para seguimiento del cumplimiento del objeto contractual.',
					},
					{
						id: 't4-gar',
						badge: 'Rol',
						frontTitle: 'Garante',
						frontSubtitle: 'Afianza obligaciones',
						backBody: 'Responde por obligaciones ante incumplimiento, usualmente mediante garantías/pólizas.',
					},
				] satisfies FlipCardItem[]}
			/>
		</div>
	)
}
