---
import FlipCards, { type FlipCardItem } from './FlipCards.astro';

interface Props {
	seccion: 'codigos' | 'triple' | 'etica';
}

const { seccion } = Astro.props;
---

{
	seccion === 'codigos' && (
		<div class="mt-6 border-t border-cyan-100 pt-5">
			<FlipCards
				theme="cyan"
				title="Marco normativo (pública)"
				columns={3}
				items={[
					{
						id: 't3-80',
						badge: 'Norma',
						frontTitle: 'Ley 80 de 1993',
						frontSubtitle: 'Estatuto general',
						backBody: 'Regula la contratación pública y define reglas generales del sistema contractual.',
					},
					{
						id: 't3-1150',
						badge: 'Norma',
						frontTitle: 'Ley 1150 de 2007',
						frontSubtitle: 'Selección y transparencia',
						backBody: 'Moderniza modalidades de selección e introduce medidas de eficiencia y transparencia.',
					},
					{
						id: 't3-1082',
						badge: 'Norma',
						frontTitle: 'Decreto 1082 de 2015',
						frontSubtitle: 'Reglamenta',
						backBody: 'Desarrolla aspectos técnicos y procedimentales para ejecutar el marco legal.',
					},
					{
						id: 't3-c83',
						badge: 'Constitución',
						frontTitle: 'Art. 83',
						frontSubtitle: 'Buena fe',
						backBody: 'Las actuaciones se presumen de buena fe en las gestiones ante la administración.',
					},
					{
						id: 't3-c209',
						badge: 'Constitución',
						frontTitle: 'Art. 209',
						frontSubtitle: 'Función administrativa',
						backBody: 'Principios: igualdad, moralidad, eficacia, economía, celeridad, imparcialidad, publicidad.',
					},
					{
						id: 't3-c90',
						badge: 'Constitución',
						frontTitle: 'Art. 90',
						frontSubtitle: 'Responsabilidad',
						backBody: 'Responsabilidad patrimonial del Estado por daños antijurídicos imputables a autoridades.',
					},
				] satisfies FlipCardItem[]}
			/>

			<div class="mt-5">
				<FlipCards
					theme="cyan"
					title="Principios rectores"
					columns={3}
					items={[
						{ id: 't3-pr-mor', badge: 'Principio', frontTitle: 'Moralidad', frontSubtitle: 'Rectitud', backBody: 'Evita desviaciones hacia intereses particulares; coherencia con legalidad y lealtad.' },
						{ id: 't3-pr-efi', badge: 'Principio', frontTitle: 'Eficacia', frontSubtitle: 'Metas', backBody: 'Capacidad de alcanzar metas y garantizar la adecuada prestación del servicio.' },
						{ id: 't3-pr-cel', badge: 'Principio', frontTitle: 'Celeridad', frontSubtitle: 'Agilidad', backBody: 'Impulso diligente del procedimiento; evita trámites innecesarios.' },
						{ id: 't3-pr-imp', badge: 'Principio', frontTitle: 'Imparcialidad', frontSubtitle: 'Objetividad', backBody: 'No favorecer intereses particulares; selección justa de contratistas.' },
						{ id: 't3-pr-pub', badge: 'Principio', frontTitle: 'Publicidad', frontSubtitle: 'Acceso', backBody: 'Actuaciones transparentes y accesibles al público; divulgación de información relevante.' },
						{ id: 't3-pr-so', badge: 'Principio', frontTitle: 'Selección objetiva', frontSubtitle: 'Criterios claros', backBody: 'Elección con criterios objetivos para mejor relación calidad–precio/costo–beneficio.' },
					] satisfies FlipCardItem[]}
				/>
			</div>

			<div class="mt-5">
				<FlipCards
					theme="cyan"
					title="Fases (pública)"
					items={[
						{
							id: 't3-f-prep',
							badge: 'Fase',
							frontTitle: 'Actos preparatorios',
							frontSubtitle: 'Necesidad → bases',
							backBody: 'Definir necesidad, plan anual, indagación de mercado, procedimiento, órgano y bases.',
						},
						{
							id: 't3-f-sel',
							badge: 'Fase',
							frontTitle: 'Selección',
							frontSubtitle: 'Convocatoria → evaluación',
							backBody: 'Convocar, recibir observaciones, integrar bases, presentar ofertas, evaluar y adjudicar.',
						},
						{
							id: 't3-f-ejec',
							badge: 'Fase',
							frontTitle: 'Ejecución',
							frontSubtitle: 'Perfeccionamiento → pago',
							backBody: 'Ejecución, seguimiento, conformidad, pagos y liquidación cuando corresponda.',
						},
						{
							id: 't3-priv-elem',
							badge: 'Privada',
							frontTitle: 'Elementos legales',
							frontSubtitle: 'Base del acuerdo',
							backBody: 'Consentimiento, objeto lícito, capacidad, forma y buena fe (según el caso).',
						},
					] satisfies FlipCardItem[]}
				/>
			</div>
		</div>
	)
}

{
	seccion === 'triple' && (
		<div class="mt-6 border-t border-cyan-100 pt-5">
			<FlipCards
				theme="cyan"
				title="Efectivo / eficaz / eficiente"
				columns={3}
				items={[
					{
						id: 't3-ee-efec',
						badge: 'Triple E',
						frontTitle: 'Efectivo',
						frontSubtitle: 'Funciona en la realidad',
						backBody: 'Se obtiene el resultado esperado de manera concreta; no solo formal.',
					},
					{
						id: 't3-ee-eficaz',
						badge: 'Triple E',
						frontTitle: 'Eficaz',
						frontSubtitle: 'Cumple objetivos',
						backBody: 'Alcanza los fines propuestos, independientemente del nivel de recursos utilizados.',
					},
					{
						id: 't3-ee-eficiente',
						badge: 'Triple E',
						frontTitle: 'Eficiente',
						frontSubtitle: 'Optimiza recursos',
						backBody: 'Logra objetivos con el mejor uso de tiempo, costo y esfuerzo (costo–beneficio).',
					},
				] satisfies FlipCardItem[]}
			/>
		</div>
	)
}

{
	seccion === 'etica' && (
		<div class="mt-6 border-t border-cyan-100 pt-5">
			<FlipCards
				theme="cyan"
				title="Ética y moral"
				items={[
					{
						id: 't3-em-moral',
						badge: 'Concepto',
						frontTitle: 'Moral',
						frontSubtitle: 'Costumbre y valores',
						backBody: 'Normas y costumbres que una comunidad asume para distinguir lo permitido y lo reprobable.',
					},
					{
						id: 't3-em-etica',
						badge: 'Concepto',
						frontTitle: 'Ética',
						frontSubtitle: 'Reflexión crítica',
						backBody: 'Disciplina que fundamenta racionalmente principios morales y guía decisiones en dilemas.',
					},
					{
						id: 't3-em-publico',
						badge: 'Aplicación',
						frontTitle: 'En contratación',
						frontSubtitle: 'Más que cumplir',
						backBody: 'Rectitud, transparencia, equidad e integridad para evitar favorecimientos y conflictos de interés.',
					},
				] satisfies FlipCardItem[]}
			/>
		</div>
	)
}
