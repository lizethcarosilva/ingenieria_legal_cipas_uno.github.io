			text-underline-offset: 3px;
			transform: scale(1.02);
		}
		.match-card {
			cursor: pointer;
			border-radius: 0.75rem;
			border: 2px solid transparent;
			padding: 0.75rem 1rem;
			font-size: 0.875rem;
			font-weight: 600;
			transition:
				transform 0.15s,
				box-shadow 0.15s;
		}
		.match-card:hover:not(:disabled) {
			transform: translateY(-2px);
		}
		.match-card.selected {
			border-color: #7c3aed;
			box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.25);
		}
		.match-card.ok {
			cursor: default;
			opacity: 0.85;
		}

		/* Ambiente y animación · temas 2, 3 y 4 */
		.ambient-tema {
			position: relative;
			isolation: isolate;
		}
		.ambient-tema::before {
			content: '';
			position: absolute;
			inset: -4px;
			z-index: -1;
			border-radius: 1.25rem;
			opacity: 0.55;
			pointer-events: none;
			background: radial-gradient(ellipse 90% 60% at 50% 0%, var(--ambient-glow, rgba(45, 212, 191, 0.22)), transparent 55%);
			animation: ambientBreath 9s ease-in-out infinite;
		}
		.ambient-tema-2 {
			--ambient-glow: rgba(45, 212, 191, 0.28);
		}
		.ambient-tema-3 {
			--ambient-glow: rgba(34, 211, 238, 0.26);
		}
		.ambient-tema-4 {
			--ambient-glow: rgba(129, 140, 248, 0.28);
		}
		@keyframes ambientBreath {
			0%,
			100% {
				opacity: 0.45;
				transform: scale(1);
			}
			50% {
				opacity: 0.75;
				transform: scale(1.01);
			}
		}

		.subte-viz {
			position: relative;
			overflow: hidden;
		}
		.subte-viz::after {
			content: '';
			position: absolute;
			inset: 0;
			background: linear-gradient(
				115deg,
				transparent 0%,
				rgba(255, 255, 255, 0.35) 45%,
				transparent 70%
			);
			transform: translateX(-120%);
			animation: vizShine 7s ease-in-out infinite;
			pointer-events: none;
			mix-blend-mode: soft-light;
		}
		.subte-viz--t2::after {
			animation-duration: 6.5s;
		}
		.subte-viz--t3::after {
			animation-duration: 7.5s;
		}
		.subte-viz--t4::after {
			animation-duration: 8s;
		}
		@keyframes vizShine {
			0%,
			100% {
				transform: translateX(-130%);
			}
			40%,
			60% {
				transform: translateX(130%);
			}
		}

		.subte-card {
			transition:
				transform 0.35s cubic-bezier(0.34, 1.45, 0.64, 1),
				box-shadow 0.35s ease;
		}
		@media (prefers-reduced-motion: no-preference) {
			.subte-viz .subte-card {
				animation: subteCardIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
			}
			.subte-viz .grid > .subte-card:nth-child(1) {
				animation-delay: 0.04s;
			}
			.subte-viz .grid > .subte-card:nth-child(2) {
				animation-delay: 0.12s;
			}
			.subte-viz .grid > .subte-card:nth-child(3) {
				animation-delay: 0.2s;
			}
			.subte-viz .flex > .subte-card:nth-child(1) {
				animation-delay: 0.05s;
			}
			.subte-viz .flex > .subte-card:nth-child(3) {
				animation-delay: 0.14s;
			}
			.subte-viz .flex > .subte-card:nth-child(5) {
				animation-delay: 0.24s;
			}
			.subte-viz .flex.flex-col > .subte-card:nth-child(1) {
				animation-delay: 0.06s;
			}
			.subte-viz .flex.flex-col > .subte-card:nth-child(3) {
				animation-delay: 0.16s;
			}
			.subte-viz .flex.flex-col > .subte-card:nth-child(5) {
				animation-delay: 0.26s;
			}
		}
		@keyframes subteCardIn {
			from {
				opacity: 0;
				transform: translateY(14px) scale(0.97);
			}
			to {
				opacity: 1;
				transform: translateY(0) scale(1);
			}
		}
		.subte-card:hover {
			transform: translateY(-5px) scale(1.02);
			box-shadow: 0 14px 28px -10px rgba(15, 23, 42, 0.22);
		}
		@media (prefers-reduced-motion: reduce) {
			.ambient-tema::before,
			.subte-viz::after {
				animation: none;
			}
			.subte-viz .subte-card {
				animation: none;
			}
		}
	</style>

	<script is:inline>
		(function () {
			/* ── Pestañas: un solo tema visible ── */
			const panels = document.querySelectorAll('.tema-panel');
			const tabs = document.querySelectorAll('.tema-tab');

			const tabStyles = {
				active: 'rounded-xl border-2 border-emerald-500 bg-emerald-50 px-3 py-2 text-left text-xs font-bold text-emerald-900 shadow-sm sm:text-sm',
				inactive: 'rounded-xl border border-neutral-200 bg-white px-3 py-2 text-left text-xs font-medium text-neutral-700 hover:border-teal-300 sm:text-sm'
			};

			function showTema(n) {
				const num = String(n);
				panels.forEach((p) => {
					const on = p.getAttribute('data-panel') === num;
					p.classList.toggle('hidden', !on);
					p.toggleAttribute('hidden', !on);
				});
				tabs.forEach((t) => {
					const on = t.getAttribute('data-tema') === num;
					t.setAttribute('aria-selected', on ? 'true' : 'false');
					t.className = 'tema-tab ' + (on ? tabStyles.active : tabStyles.inactive);
				});
				try {
					history.replaceState(null, '', '#tema-' + num);
				} catch (e) {}
			}

			tabs.forEach((t) => {
				t.addEventListener('click', () => showTema(t.getAttribute('data-tema')));
			});

			if (location.hash && /^#tema-[1-4]$/.test(location.hash)) {
				showTema(location.hash.replace('#tema-', ''));
			} else {
				showTema('1');
			}

			/* ── Sopa de letras Tema 1 (horizontal y vertical; rejilla estable) ── */
			/* Palabras del tema 1 — Jerarquía de normas y proceso contractual (GUÍA 1) */
			const T1_WORDS = ['PIRAMIDE', 'NORMA', 'ETAPA', 'LEY', 'NIVEL', 'PACTO'];
			const SOPA_ROWS = 10;
			const SOPA_COLS = 14;
			const ABC = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
			function randLetter() {
				return ABC[Math.floor(Math.random() * ABC.length)];
			}
			function emptyGrid() {
				const g = [];
				for (let r = 0; r < SOPA_ROWS; r++) {
					const row = [];
					for (let c = 0; c < SOPA_COLS; c++) row.push({ ch: randLetter(), sol: false });
					g.push(row);
				}
				return g;
			}
			function canPlace(g, w, horiz, r, c) {
				for (let i = 0; i < w.length; i++) {
					const rr = horiz ? r : r + i;
					const cc = horiz ? c + i : c;
					const cell = g[rr][cc];
					if (cell.sol && cell.ch !== w[i]) return false;
				}
				return true;
			}
			function applyPlace(g, w, horiz, r, c) {
				const cells = [];
				for (let i = 0; i < w.length; i++) {
					const rr = horiz ? r : r + i;
					const cc = horiz ? c + i : c;
					g[rr][cc].ch = w[i];
					g[rr][cc].sol = true;
					cells.push([rr, cc]);
				}
				return cells;
			}
			function tryPlaceWord(g, word) {
				const w = word.replace(/\s/g, '').toUpperCase();
				if (w.length === 0) return null;
				for (let t = 0; t < 400; t++) {
					const horiz = Math.random() < 0.5;
					let r, c;
					if (horiz) {
						r = Math.floor(Math.random() * SOPA_ROWS);
						c = Math.floor(Math.random() * Math.max(1, SOPA_COLS - w.length + 1));
					} else {
						r = Math.floor(Math.random() * Math.max(1, SOPA_ROWS - w.length + 1));
						c = Math.floor(Math.random() * SOPA_COLS);
					}
					if (canPlace(g, w, horiz, r, c)) {
						const cells = applyPlace(g, w, horiz, r, c);
						return { word: word, cells: cells };
					}
				}
				return null;
			}
			function buildGrid() {
				const order = [...T1_WORDS].sort((a, b) => b.length - a.length);
				for (let attempt = 0; attempt < 80; attempt++) {
					const g = emptyGrid();
					const placements = [];
					let ok = true;
					for (const p of order) {
						const res = tryPlaceWord(g, p);
						if (!res) {
							ok = false;
							break;
						}
						placements.push(res);
					}
					if (ok) return { grid: g, placements: placements };
				}
				return { grid: emptyGrid(), placements: [] };
			}
			function renderSopa1(bundle, foundWords) {
				const tabla = document.getElementById('t1-sopa-tabla');
				const palWrap = document.getElementById('t1-sopa-palabras');
				const g = bundle.grid;
				const placements = bundle.placements;
				if (!tabla || !palWrap) return;
				tabla.innerHTML = '';
				palWrap.innerHTML = T1_WORDS.map((p) => {
					const done = foundWords.has(p);
					return (
						'<span data-sopa-word="' +
						p +
						'" class="sopa-chip rounded-lg border border-amber-200 bg-white px-2 py-1 text-xs font-bold text-amber-900 ' +
						(done ? 'sopa-chip-found' : '') +
						'">' +
						p +
						'</span>'
					);
				}).join('');
				for (let r = 0; r < SOPA_ROWS; r++) {
					const tr = document.createElement('tr');
					for (let c = 0; c < SOPA_COLS; c++) {
						const td = document.createElement('td');
						td.className = 'sopa-celda';
						td.textContent = g[r][c].ch;
						td.dataset.r = String(r);
						td.dataset.c = String(c);
						if (g[r][c].sol) td.dataset.sol = '1';
						const isFoundCell = placements.some(
							(pl) => foundWords.has(pl.word) && pl.cells.some((x) => x[0] === r && x[1] === c)
						);
						if (isFoundCell) td.classList.add('sopa-found');
						tr.appendChild(td);
					}
					tabla.appendChild(tr);
				}
				function getTd(rr, cc) {
					const row = tabla.rows[rr];
					return row ? row.cells[cc] : null;
				}
				function cellMarked(cell) {
					return (
						cell &&
						(cell.classList.contains('sopa-pick') || cell.classList.contains('sopa-found'))
					);
				}
				function checkWords() {
					placements.forEach((pl) => {
						if (foundWords.has(pl.word)) return;
						const ok = pl.cells.every(([rr, cc]) => cellMarked(getTd(rr, cc)));
						if (ok) {
							foundWords.add(pl.word);
							pl.cells.forEach(([rr, cc]) => {
								const cell = getTd(rr, cc);
								if (cell) {
									cell.classList.remove('sopa-pick');
									cell.classList.add('sopa-found');
								}
							});
							const chip = palWrap.querySelector('[data-sopa-word="' + pl.word + '"]');
							if (chip) chip.classList.add('sopa-chip-found');
						}
					});
					if (foundWords.size === T1_WORDS.length) {
						const el = document.getElementById('t1-sopa-complete');
						if (el) el.classList.remove('hidden');
					}
				}
				tabla.querySelectorAll('.sopa-celda').forEach((td) => {
					td.addEventListener('click', function () {
						if (this.classList.contains('sopa-found')) return;
						this.classList.toggle('sopa-pick');
						checkWords();
					});
				});
			}
			function toggleT1(on) {
				document.querySelectorAll('#t1-sopa-tabla .sopa-celda').forEach((td) => {
					if (td.dataset.sol === '1') td.classList.toggle('sol', on);
				});
			}
			function initT1() {
				const b1 = document.getElementById('t1-sopa-sol');
				const b2 = document.getElementById('t1-sopa-hide');
				const b3 = document.getElementById('t1-sopa-new');
				const bClear = document.getElementById('t1-sopa-clear-pick');
				if (!b1 || !b2 || !b3 || !bClear || b1.dataset.bound === '1') return;
				b1.dataset.bound = '1';
				let foundWords = new Set();
				let currentBundle = { grid: [], placements: [] };
				function paint() {
					toggleT1(false);
					foundWords = new Set();
					const doneEl = document.getElementById('t1-sopa-complete');
					if (doneEl) doneEl.classList.add('hidden');
					currentBundle = buildGrid();
					renderSopa1(currentBundle, foundWords);
				}
				paint();
				b1.addEventListener('click', () => toggleT1(true));
				b2.addEventListener('click', () => toggleT1(false));
				bClear.addEventListener('click', () => {
					document.querySelectorAll('#t1-sopa-tabla .sopa-pick').forEach((td) => td.classList.remove('sopa-pick'));
				});
				b3.addEventListener('click', paint);
			}

			/* ── Relaciona Tema 2 ── */
			const PAIRS = [
				['TVEC', 'Tienda Virtual del Estado'],
				['SECOP II', 'Contratación pública en línea'],
				['AMP', 'Acuerdo Marco de Precios'],
				['Pliego', 'Reglas del proceso de selección'],
			];
			function initT2() {
				const root = document.getElementById('t2-match-root');
				const status = document.getElementById('t2-match-status');
				if (!root || root.dataset.ready === '1') return;
				root.dataset.ready = '1';
				const left = PAIRS.map((p, i) => ({ id: i, label: p[0], done: false }));
				const right = PAIRS.map((p, i) => ({ id: i, label: p[1], done: false })).sort(() => Math.random() - 0.5);
				let selected = null;
				let found = 0;
				function render() {
					root.innerHTML = '';
					const colA = document.createElement('div');
					const colB = document.createElement('div');
					colA.className = 'space-y-2';
					colB.className = 'space-y-2';
					const h = (t) => {
						const p = document.createElement('p');
						p.className = 'text-xs font-bold uppercase text-violet-600';
						p.textContent = t;
						return p;
					};
					colA.appendChild(h('Columna A'));
					colB.appendChild(h('Columna B'));
					left.forEach((item) => {
						if (item.done) return;
						const b = document.createElement('button');
						b.type = 'button';
						b.className = 'match-card w-full bg-violet-100 text-violet-900';
						b.textContent = item.label;
						b.dataset.side = 'L';
						b.dataset.id = String(item.id);
						b.addEventListener('click', onPick);
						colA.appendChild(b);
					});
					right.forEach((item) => {
						if (item.done) return;
						const b = document.createElement('button');
						b.type = 'button';
						b.className = 'match-card w-full bg-fuchsia-100 text-fuchsia-900';
						b.textContent = item.label;
						b.dataset.side = 'R';
						b.dataset.id = String(item.id);
						b.addEventListener('click', onPick);
						colB.appendChild(b);
					});
					root.appendChild(colA);
					root.appendChild(colB);
				}
				function onPick(ev) {
					const btn = ev.currentTarget;
					if (!selected) {
						selected = btn;
						btn.classList.add('selected');
						return;
					}
					if (selected === btn) {
						selected.classList.remove('selected');
						selected = null;
						return;
					}
					if (selected.dataset.side === btn.dataset.side) {
						selected.classList.remove('selected');
						selected = btn;
						btn.classList.add('selected');
						return;
					}
					const idA = selected.dataset.side === 'L' ? +selected.dataset.id : +btn.dataset.id;
					const idB = selected.dataset.side === 'R' ? +selected.dataset.id : +btn.dataset.id;
					selected.classList.remove('selected');
					selected = null;
					if (idA === idB) {
						left.find((x) => x.id === idA).done = true;
						right.find((x) => x.id === idB).done = true;
						found++;
						status.textContent = 'Pares encontrados: ' + found + ' / 4';
						render();
					}
				}
				render();
			}

			/* ── Carrusel V/F Tema 3 (una afirmación por pantalla) ── */
			const T3_VF = [
				{ q: 'El Código Civil regula principalmente relaciones entre particulares.', a: true },
				{ q: 'Ser eficiente implica siempre ignorar el costo de los recursos.', a: false },
				{ q: 'La ética reflexiona de forma crítica sobre principios morales.', a: true }
			];
			function initT3() {
				const root = document.getElementById('t3-carousel-root');
				const scoreEl = document.getElementById('t3-carousel-score');
				if (!root || root.dataset.ready === '1') return;
				root.dataset.ready = '1';
				let idx = 0;
				let ok = 0;
				function render() {
					if (scoreEl) scoreEl.textContent = '';
					if (idx >= T3_VF.length) {
						root.innerHTML =
							'<p class="text-sm font-semibold text-cyan-900">Resultado: ' +
							ok +
							' / ' +
							T3_VF.length +
							' correctas.</p><button type="button" id="t3vf-retry" class="mt-3 rounded-xl bg-cyan-600 px-4 py-2 text-sm font-bold text-white">Repetir</button>';
						document.getElementById('t3vf-retry').addEventListener('click', () => {
							idx = 0;
							ok = 0;
							render();
						});
						return;
					}
					const item = T3_VF[idx];
					let answered = false;
					root.innerHTML =
						'<p class="text-xs font-bold text-cyan-700">Pregunta ' +
						(idx + 1) +
						' / ' +
						T3_VF.length +
						'</p><p class="mt-2 text-sm font-medium text-neutral-900">' +
						item.q +
						'</p><div class="mt-4 flex flex-wrap gap-2"><button type="button" class="t3vf-b rounded-lg bg-emerald-600 px-4 py-2 text-sm font-bold text-white hover:bg-emerald-700" data-v="1">Verdadero</button><button type="button" class="t3vf-b rounded-lg border border-cyan-300 bg-white px-4 py-2 text-sm font-bold text-cyan-900 hover:bg-cyan-50" data-v="0">Falso</button></div><p id="t3vf-fb" class="mt-3 hidden text-sm font-semibold"></p><button type="button" id="t3vf-next" class="mt-2 hidden rounded-xl bg-cyan-600 px-4 py-2 text-sm font-bold text-white">Siguiente</button>';
					const fb = document.getElementById('t3vf-fb');
					const next = document.getElementById('t3vf-next');
					root.querySelectorAll('.t3vf-b').forEach((b) => {
						b.addEventListener('click', () => {
							if (answered) return;
							answered = true;
							const v = b.dataset.v === '1';
							const right = item.a === v;
							if (right) ok++;
							fb.classList.remove('hidden');
							fb.textContent = right ? 'Correcto.' : 'Revisa el subtema correspondiente arriba.';
							fb.className = 'mt-3 text-sm font-semibold ' + (right ? 'text-emerald-700' : 'text-rose-600');
							root.querySelectorAll('.t3vf-b').forEach((x) => (x.disabled = true));
							next.classList.remove('hidden');
						});
					});
					next.addEventListener('click', () => {
						idx++;
						render();
					});
				}
				render();
			}

			/* ── Mini test Tema 4 (una pregunta, auto-avance) ── */
			const T4_MCQ = [
				{
					q: 'El licenciamiento de software permite usar el programa sin:',
					opts: ['Ceder la propiedad intelectual', 'Cumplir el pliego de condiciones', 'Registrar obligatoriamente en SECOP'],
					ok: 0
				},
				{
					q: 'Quien ejecuta el servicio u obra frente a contraprestación suele ser:',
					opts: ['El contratante', 'El contratista', 'El garante'],
					ok: 1
				},
				{
					q: 'La cesión del contrato, en términos generales, requiere:',
					opts: ['Solo publicar en la TVEC', 'Consentimiento de la contraparte', 'Anuncio en medios masivos'],
					ok: 1
				}
			];
			function initT4() {
				const root = document.getElementById('t4-mcq-root');
				if (!root || root.dataset.ready === '1') return;
				root.dataset.ready = '1';
				let i = 0;
				let score = 0;
				function render() {
					if (i >= T4_MCQ.length) {
						root.innerHTML =
							'<p class="text-sm font-semibold text-indigo-900">Puntuación: ' +
							score +
							' / ' +
							T4_MCQ.length +
							'</p><button type="button" id="t4-retry" class="mt-3 rounded-xl bg-indigo-600 px-4 py-2 text-sm font-bold text-white">Repetir</button>';
						document.getElementById('t4-retry').addEventListener('click', () => {
							i = 0;
							score = 0;
							render();
						});
						return;
					}
					const item = T4_MCQ[i];
					const optsHtml = item.opts
						.map(
							(o, j) =>
								`<button type="button" class="t4o mb-2 w-full rounded-lg border border-indigo-200 bg-white px-3 py-2 text-left text-sm text-neutral-800 hover:bg-indigo-50" data-j="${j}">${o}</button>`
						)
						.join('');
					root.innerHTML =
						'<p class="text-xs font-bold text-indigo-700">' +
						(i + 1) +
						' / ' +
						T4_MCQ.length +
						'</p><p class="mt-2 text-sm font-medium text-neutral-900">' +
						item.q +
						'</p><div class="mt-3">' +
						optsHtml +
						'</div><p id="t4o-fb" class="mt-2 min-h-[1.25rem] text-xs font-semibold"></p>';
					root.querySelectorAll('.t4o').forEach((btn) => {
						btn.addEventListener('click', () => {
							if (root.querySelector('.t4o[disabled]')) return;
							const j = +btn.dataset.j;
							const right = j === item.ok;
							if (right) score++;
							const fb = document.getElementById('t4o-fb');
							fb.textContent = right ? 'Correcto.' : 'Revisa el subtema correspondiente arriba.';
							fb.className = 'mt-2 text-xs font-semibold ' + (right ? 'text-emerald-700' : 'text-rose-600');
							root.querySelectorAll('.t4o').forEach((b) => (b.disabled = true));
							window.setTimeout(() => {
								i++;
								render();
							}, 550);
						});
					});
				}
				render();
			}

			function initSubtemaTabs(panelId, prefix, activeCls, inactiveCls) {
				const sec = document.getElementById(panelId);
				if (!sec || sec.dataset.subready === '1') return;
				sec.dataset.subready = '1';
				const btns = sec.querySelectorAll('.' + prefix + '-sub-btn');
				const panels = sec.querySelectorAll('.' + prefix + '-sub-panel');
				btns.forEach((btn) => {
					btn.addEventListener('click', () => {
						const n = btn.getAttribute('data-sub');
						btns.forEach((b) => {
							const on = b.getAttribute('data-sub') === n;
							b.setAttribute('aria-selected', on ? 'true' : 'false');
							b.className = prefix + '-sub-btn ' + (on ? activeCls : inactiveCls);
						});
						panels.forEach((p) => {
							const show = p.id === prefix + '-sub-' + n;
							p.classList.toggle('hidden', !show);
						});
					});
				});
			}

			function onPanelVisible() {
				initT1();
				initT2();
				initT3();
				initT4();
				initSubtemaTabs(
					'panel-tema-2',
					't2',
					'tab-btn px-4 py-2 rounded-xl font-medium border transition shadow-sm bg-gradient-to-r from-teal-600 to-cyan-600 text-white border-teal-600',
					'tab-btn px-4 py-2 rounded-xl font-medium border transition shadow-sm bg-white/70 text-teal-900 border-teal-100 hover:bg-teal-50'
				);
				initSubtemaTabs(
					'panel-tema-3',
					't3',
					'tab-btn px-4 py-2 rounded-xl font-medium border transition shadow-sm bg-gradient-to-r from-cyan-600 to-sky-600 text-white border-cyan-600',
					'tab-btn px-4 py-2 rounded-xl font-medium border transition shadow-sm bg-white/70 text-cyan-900 border-cyan-100 hover:bg-cyan-50'
				);
				initSubtemaTabs(
					'panel-tema-4',
					't4',
					'tab-btn px-4 py-2 rounded-xl font-medium border transition shadow-sm bg-gradient-to-r from-indigo-600 to-violet-600 text-white border-indigo-600',
					'tab-btn px-4 py-2 rounded-xl font-medium border transition shadow-sm bg-white/70 text-indigo-900 border-indigo-100 hover:bg-indigo-50'
				);
			}

			function boot() {
				onPanelVisible();
				window.addEventListener('hashchange', () => {
					if (location.hash && /^#tema-[1-4]$/.test(location.hash)) {
						showTema(location.hash.replace('#tema-', ''));
					}
				});
			}
			if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
			else boot();
		})();
	</script>
</Page>
