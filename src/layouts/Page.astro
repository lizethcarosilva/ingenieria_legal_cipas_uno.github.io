---
import LiquidEtherHero from "../components/LiquidEtherHero.astro";
import "../styles/tailwind.css";

const { title = "Ingeniería Legal — CIPA Uno" } = Astro.props;
const basePath = import.meta.env.BASE_URL;

function withBase(path: string) {
	const normalized = path.startsWith("/") ? path.slice(1) : path;
	if (!normalized) return basePath;
	return basePath + normalized;
}

function getCurrentPath() {
	const pathnameRaw = Astro.url.pathname;
	const pathname = pathnameRaw.endsWith("/") && pathnameRaw.length > 1 ? pathnameRaw.slice(0, -1) : pathnameRaw;
	const baseNoSlash = basePath.replace(/\/$/, "");
	if (pathname === baseNoSlash) return "/";
	const prefix = baseNoSlash + "/";
	if (pathname.startsWith(prefix)) {
		const rest = pathname.slice(prefix.length);
		return rest ? "/" + rest : "/";
	}
	return pathname || "/";
}

type NavItem = { label: string; path: string; exact?: boolean };

const navItems: NavItem[] = [
	{ label: "Inicio", path: "", exact: true },
	{ label: "Justificación", path: "justificacion" },
	{ label: "Tutoría Uno", path: "tutoria-uno" },
	{ label: "Tutoría Dos", path: "tutoria-dos" },
	{ label: "Tutoría Tres", path: "tutoria-tres" },
	{ label: "Tutoría Cuatro", path: "tutoria-cuatro" },
	{ label: "Tutoría Cinco", path: "tutoria-cinco" },
	{ label: "Convocatoria", path: "convocatoria" },
];

const currentPath = getCurrentPath();

function hrefFor(path: string) {
	return withBase(path);
}

function activeClass(path: string, exact?: boolean) {
	const target = path ? "/" + path : "/";
	const isActive = exact ? currentPath === target : currentPath.startsWith(target);
	return isActive ? "active" : "";
}

const favicon = withBase("favicon.svg");
---
<html lang="es" class="h-full">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={favicon} />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body class="relative min-h-full text-neutral-900">
		<LiquidEtherHero />
		<header class="sticky top-0 z-20 border-b border-white/40 bg-white/55 shadow-[0_8px_30px_rgba(82,39,255,0.08)] backdrop-blur-xl">
			<div class="max-w-[1200px] mx-auto px-3 py-3 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
				<a href={hrefFor("")} class="text-emerald-900 tracking-tight text-sm sm:text-base shrink-0 font-bold hover:opacity-90 transition">
					INGENIERÍA LEGAL · CIPA UNO
				</a>
				<nav class="flex flex-wrap items-center gap-1.5 justify-start sm:justify-end">
					{navItems.map((item) => (
						<a
							href={hrefFor(item.path)}
							class={
								"px-2.5 py-1.5 rounded-lg text-xs sm:text-sm font-medium transition shadow-sm hover:-translate-y-0.5 hover:shadow-md " +
								(activeClass(item.path, item.exact)
									? "bg-gradient-to-r from-emerald-600 to-teal-600 text-white shadow-emerald-500/25"
									: "bg-white/85 text-emerald-900 hover:bg-white border border-emerald-100/80")
							}
						>
							{item.label}
						</a>
					))}
				</nav>
			</div>
		</header>
		<main class="max-w-[1200px] mx-auto px-3 py-8 relative">
			<slot />
		</main>
		<footer class="border-t border-white/50 bg-white/70 backdrop-blur-md mt-8">
			<div class="max-w-[1200px] mx-auto px-3 py-4 text-sm text-neutral-600 text-center">
				© 2026 Universidad del Tolima · IDEAD · Ingeniería de Sistemas
			</div>
		</footer>
	</body>
</html>
